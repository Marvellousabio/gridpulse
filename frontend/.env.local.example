# Mock mode (default) — no env needed

# Live GridPulse API on Render (FE dev — no Cencori key needed):
NEXT_PUBLIC_API_BASE=https://your-gridpulse-api.onrender.com

# Alias also supported:
# NEXT_PUBLIC_API_URL=https://your-gridpulse-api.onrender.com

# Cencori — backend/Render ONLY. Do not add here unless running Next /api/agent/* locally:
# CENCORI_API_KEY=csk_...
