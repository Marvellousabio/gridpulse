# GridPulse API — environment template (copy to .env)
HOST=0.0.0.0
PORT=5000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Cencori AI Gateway (preferred — routes via https://api.cencori.com/v1)
CENCORI_API_KEY=csk_...
CENCORI_MODEL=claude-sonnet-4.5
# Optional trace/agent attribution header for native endpoints
# CENCORI_AGENT_ID=

# Optional Anthropic direct fallback when Cencori is unavailable
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Enable AI reasoning on rebalance (Cencori first, then Anthropic fallback)
AI_REASONING=true

# Telemetry simulation interval (seconds)
TELEMETRY_INTERVAL_SECONDS=5

# Auto-run LangGraph balancer when critical telemetry is detected
AUTO_AGENT_CYCLES=false

# Standalone telemetry script target
API_BASE_URL=http://localhost:5000
