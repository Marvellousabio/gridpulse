# GridPulse API — environment template (copy to .env)
HOST=0.0.0.0
PORT=5000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: Cencori AI Gateway (leave empty for local passthrough)
CENCORI_API_URL=
CENCORI_API_KEY=

# Claude API — powers rebalance FORECAST/ALLOCATE + reasoning trace
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
CLAUDE_REASONING=true

# Telemetry simulation interval (seconds)
TELEMETRY_INTERVAL_SECONDS=5

# Auto-run LangGraph balancer when critical telemetry is detected
# Set false during staged demo (use Orchestration trigger instead)
AUTO_AGENT_CYCLES=false

# Standalone telemetry script target (for EC2 / local simulator)
API_BASE_URL=http://localhost:5000
