# GridPulse API — environment template (copy to .env)
HOST=0.0.0.0
PORT=5000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: Cencori AI Gateway (leave empty for local passthrough)
CENCORI_API_URL=
CENCORI_API_KEY=

# Telemetry simulation interval (seconds)
TELEMETRY_INTERVAL_SECONDS=5

# Auto-run LangGraph balancer when critical telemetry is detected
AUTO_AGENT_CYCLES=true

# Standalone telemetry script target (for EC2 / local simulator)
API_BASE_URL=http://localhost:5000
